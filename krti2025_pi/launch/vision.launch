<launch>

    <node name="vision" pkg="krti2024_pi" type="vision.py" args="" output="screen">
        <rosparam>
            <!-- for guided in real life, set to false -->
            use_sim: true
            verbose: true
            camera_index: 0

            <!-- PAYLOAD LANUD -->
            <!-- target_lower_hsv: [7, 52, 94] -->
            <!-- target_upper_hsv: [17, 196, 255] -->

            <!-- PAYLOAD LANUD -->
            <!-- target_lower_hsv: [3, 0, 235]
            target_upper_hsv: [69, 116, 255] -->
            
            <!-- SHULTAN TEST -->
            <!-- target_lower_hsv: [0, 70, 6] -->
            <!-- target_upper_hsv: [70, 255, 255] -->

            target_lower_hsv: [5, 70,20]
            target_upper_hsv: [30, 255,255]

            <!-- EMBER LANUD-->
            <!-- target2_lower_hsv: [0, 195, 72] -->
            <!-- target2_upper_hsv: [183, 255, 170] -->
            
            target2_lower_hsv: [0, 255, 90]
            target2_upper_hsv: [1, 255, 249]

            <!-- EMBER LANUD-->
            <!-- target2_lower_hsv: [0, 195, 72] -->
            <!-- target2_upper_hsv: [183, 255, 170] -->
            target5_lower_hsv: [132, 30, 106]
            target5_upper_hsv: [175, 208, 255]

            <!-- RED BLOCK PLATE -->
            target3_lower_hsv: [16, 19,100]
            target3_upper_hsv: [42, 89,227]
            
            <!-- GREY PLATE -->
            target4_lower_hsv: [76, 34,248]
            target4_upper_hsv: [107, 79,255]

            <!-- LANDING KANAN = MERAH -->
            <!-- target6_lower_hsv: [138, 45, 157] -->
            <!-- target6_upper_hsv: [225, 193, 255] -->
            
            <!-- LANDING KIRI = BIRU -->
            target6_lower_hsv: [79, 2, 215]
            target6_upper_hsv: [126, 223, 255]

            <!-- ONLY FOR SIMULATION -->
            target7_lower_hsv: [0, 0, 0]
            target7_upper_hsv: [0, 0, 0]

            front_fov_x: 78
            front_fov_y: 78
            down_fov_x: 78
            down_fov_y: 78
        </rosparam>
    </node>
    
</launch>
